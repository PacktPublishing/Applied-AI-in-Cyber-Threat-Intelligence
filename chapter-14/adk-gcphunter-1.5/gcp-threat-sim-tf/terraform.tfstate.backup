        }
      ]
    },
    "gcloud_hunt_commands": {
      "value": {
        "hunt_all_simulation_activity": "gcloud logging read \\\r\n  'timestamp\u003e=\"2026-03-01T05:06:07Z\" AND (\r\n    protoPayload.authenticationInfo.principalEmail=~\".*scenario-a.*\" OR\r\n    protoPayload.authenticationInfo.principalEmail=~\".*itadm.*\" OR\r\n    resource.labels.instance_name=~\".*scenario-a.*\" OR\r\n    resource.labels.instance_name=~\".*xmrig.*\"\r\n  )' \\\r\n  --limit=500 \\\r\n  --format=json \\\r\n  --project=xtec-lab\r\n",
        "hunt_firewall_modifications": "gcloud logging read \\\r\n  'resource.type=\"gce_firewall_rule\" AND\r\n   protoPayload.methodName=~\".*firewalls.*\" AND\r\n   timestamp\u003e=\"2026-03-01T05:06:07Z\"' \\\r\n  --limit=50 \\\r\n  --format=json \\\r\n  --project=xtec-lab\r\n",
        "hunt_iam_policy_changes": "gcloud logging read \\\r\n  'protoPayload.methodName=\"SetIamPolicy\" AND\r\n   timestamp\u003e=\"2026-03-01T05:06:07Z\"' \\\r\n  --limit=100 \\\r\n  --format=json \\\r\n  --project=xtec-lab\r\n",
        "hunt_snapshot_deletions": "gcloud logging read \\\r\n  'protoPayload.methodName=~\".*snapshot.*delete\" AND\r\n   timestamp\u003e=\"2026-03-01T05:06:07Z\"' \\\r\n  --limit=50 \\\r\n  --format=json \\\r\n  --project=xtec-lab\r\n",
        "hunt_vm_creations": "gcloud logging read \\\r\n  'protoPayload.methodName=\"v1.compute.instances.insert\" AND\r\n   timestamp\u003e=\"2026-03-01T05:06:07Z\"' \\\r\n  --limit=100 \\\r\n  --format=json \\\r\n  --project=xtec-lab\r\n"
      },
      "type": [
